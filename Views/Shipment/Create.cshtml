@model ShipmentApp.Models.Shipment
@{
    ViewData["Title"] = "Create Shipment";
}

<h1>Create Shipment</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label asp-for="CustomerName" class="control-label"></label>
                <input asp-for="CustomerName" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Origin" class="control-label"></label>
                <input asp-for="Origin" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Destination" class="control-label"></label>
                <input asp-for="Destination" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="ExpectedDeliveryDate" class="control-label">Expected Delivery Date</label>
                <input asp-for="ExpectedDeliveryDate" class="form-control" type="date" required />
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>
